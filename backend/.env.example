import dotenv from "dotenv";
dotenv.config();

function requireEnv(key: string): string {
  const value = process.env[key];
  if (!value) {
    throw new Error(`[ENV] Thiếu biến môi trường: ${key}`);
  }
  return value;
}

function toNumber(value: string | undefined, defaultValue: number): number {
  const num = Number(value);
  return isNaN(num) ? defaultValue : num;
}

export const env = {
  pinataApiKey: requireEnv("PINATA_API_KEY"),
  pinataSecretKey: requireEnv("PINATA_SECRET_API_KEY"),
  pinataGateway: process.env.PINATA_GATEWAY ?? "https://gateway.pinata.cloud/ipfs",

  db: {
    host: process.env.DB_HOST ?? "localhost",
    port: toNumber(process.env.DB_PORT, 3306),
    user: process.env.DB_USER ?? "root",
    password: requireEnv("DB_PASSWORD"), 
    name: process.env.DB_NAME ?? "tunechain",
  },

  port: toNumber(process.env.PORT, 4000),
  corsOrigin: process.env.CORS_ORIGIN ?? "http://localhost:5173",

  viewRateLimit: toNumber(process.env.VIEW_RATE_LIMIT, 5),
  viewRateWindowMs: toNumber(process.env.VIEW_RATE_WINDOW_MS, 3600000),
};
