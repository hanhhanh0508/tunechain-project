    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.4",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/form-data": "^2.2.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "chai": "^6.2.2",
    "ethers": "^6.16.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.4.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
