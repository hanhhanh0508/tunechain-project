{
  "name": "blockchain-project",
  "version": "1.0.0",
  "private": true,
  "description": "TuneChain monorepo",
  "workspaces": [
    "backend",
    "blockchain",
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run -ws build --if-present",
    "test": "npm run -ws test --if-present",
    "lint": "npm run -ws lint --if-present",
    "deploy:blockchain": "npm run test:blockchain && npm run deploy:rpc -w blockchain",
    "test:blockchain": "npm run test -w blockchain"
  },
  "keywords": [
    "monorepo",
    "blockchain",
    "dapp"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
